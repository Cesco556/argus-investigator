# --- Agent provider (need at least one) ---

# Anthropic — primary, recommended
ANTHROPIC_API_KEY=

# Azure OpenAI — fallback (also used when AGENT_MODEL=azure:mini)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=

# Optional: pin a specific model
# Values: anthropic:sonnet (default) | anthropic:opus | azure:mini
# AGENT_MODEL=anthropic:sonnet

# --- AML platform endpoints ---

# FastAPI AML engine (defaults to the public LON1 droplet if unset)
AML_ENGINE_URL=http://139.59.182.126:8000

# MCP server providing the agent's tools
MCP_SERVER_URL=http://127.0.0.1:3333/mcp

# --- MongoDB Atlas (Week 3 Suspicion Trail) ---

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=argus-investigator
MONGODB_DB_NAME=argus

# --- App ---

NEXT_PUBLIC_APP_NAME=Argus
